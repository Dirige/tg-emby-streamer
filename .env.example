# ============================================================
# Telegram Emby Streamer - 配置文件模板
# Telegram Emby Streamer - Configuration Template
# ============================================================
# 复制此文件为 .env 并填入你的配置
# Copy this file to .env and fill in your configuration
# ============================================================

# -------------------- Telegram --------------------

# Telegram API 凭据 (从 https://my.telegram.org 获取)
# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# 手机号 (仅用于生成 Session String)
# Phone number (only used for session generation)
TELEGRAM_PHONE=+8613800000000

# 用户 ID (你的 Telegram 数字 ID)
# User ID (your Telegram numeric ID)
TELEGRAM_USER_ID=your_user_id_here

# Bot Token (从 @BotFather 获取，用于流媒体下载)
# Bot Token (get from @BotFather, used for media streaming)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Session String (运行 python generate_session.py 生成)
# Session String (run python generate_session.py to generate)
TELEGRAM_SESSION_STRING=

# 私有群聊/频道 ID (存储媒体的目标，负数)
# Private group/channel ID (target for media storage, negative number)
TELEGRAM_CHANNEL_ID=-1001234567890

# 监听频道列表 (逗号分隔的频道 ID，负数)
# Monitor channels (comma-separated channel IDs, negative numbers)
TELEGRAM_MONITOR_CHANNELS=-1001111111111,-1002222222222

# 频道分类映射 (channel_id=category，逗号分隔)
# 可用分类: tv, movie, anime, dongman, cosplay, variety, documentary
# Channel category mapping (channel_id=category, comma-separated)
# Available categories: tv, movie, anime, dongman, cosplay, variety, documentary
CHANNEL_CATEGORIES=-1001111111111=movie,-1002222222222=tv

# 18+ 频道列表 (逗号分隔)
# Adult channel list (comma-separated)
ADULT_CHANNELS=

# 额外 Bot Token (用于流媒体负载均衡，逗号分隔)
# Additional Bot Tokens (for streaming load balancing, comma-separated)
TELEGRAM_BOT_TOKENS=

# -------------------- 代理 / Proxy --------------------

# 外部代理 (如果使用 sing-box 或直连，设为 false)
# External proxy (set to false if using sing-box or direct connection)
PROXY_ENABLED=false
PROXY_SCHEME=socks5
PROXY_HOST=127.0.0.1
PROXY_PORT=10808

# 订阅地址 (自动获取代理节点，可选)
# Subscription URL (auto-fetch proxy nodes, optional)
PROXY_SUB_URL=

# -------------------- sing-box --------------------

# sing-box 内置代理 (VLESS/Trojan/VMess)
# sing-box built-in proxy (VLESS/Trojan/VMess)
SINGBOX_ENABLED=false
SINGBOX_ADDRESS=your_server_address
SINGBOX_PORT=443
SINGBOX_UUID=your_uuid_or_password
SINGBOX_PATH=/?ed=2048
SINGBOX_HOST=your_host_or_sni
SINGBOX_TLS=true
SINGBOX_FINGERPRINT=chrome
SINGBOX_SOCKS_PORT=10808
SINGBOX_PROTOCOL=vless
SINGBOX_CIPHER=auto

# -------------------- 流媒体 / Stream --------------------

# 监听地址 / Listen host
STREAM_HOST=0.0.0.0

# 监听端口 / Listen port
STREAM_PORT=8001

# 外网访问地址 (用于生成 STRM 文件中的 URL，必须包含端口)
# External URL (used in STRM files, must include port)
BASE_URL=http://your-server-ip:8001

# 内网访问地址 / Internal URL
STREAM_LOCAL_URL=http://localhost:8001

# 并发下载数 / Concurrent downloads
STREAM_CONCURRENCY=3

# 最大重试次数 / Max retry attempts
STREAM_MAX_RETRIES=3

# 重试延迟 (秒) / Retry delay (seconds)
STREAM_RETRY_DELAY=2.0

# -------------------- 数据库 / Database --------------------

# 数据库 URL (默认使用 SQLite)
# Database URL (SQLite by default)
DATABASE_URL=sqlite:///./data/media.db

# -------------------- 缓存 / Cache --------------------

# 缓存目录 / Cache directory
CACHE_DIR=./cache

# 媒体目录 / Media directory
MEDIA_PATH=./media

# 内存缓存大小 (MB) / Memory cache size (MB)
MEMORY_CACHE_SIZE=256

# 磁盘缓存上限 (GB) / Disk cache limit (GB)
DISK_CACHE_MAX_GB=50

# -------------------- STRM --------------------

# STRM 文件输出目录 / STRM file output directory
STRM_OUTPUT_DIR=./strm

# -------------------- Web 面板 / Web Dashboard --------------------

# Web 面板用户名 (留空则无需登录)
# Web dashboard username (leave empty to disable auth)
WEB_USERNAME=

# Web 面板密码 / Web dashboard password
WEB_PASSWORD=

# -------------------- Emby / Jellyfin --------------------

# Emby 服务器地址 / Emby server URL
EMBY_HOST=http://localhost:8096

# Emby API Key / Emby API Key
EMBY_API_KEY=
