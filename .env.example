# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+8613300000000
TELEGRAM_USER_ID=your_user_id_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_SESSION_STRING=

# Private channel to forward media to (e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=-1001234567890

# Channels to monitor (comma-separated chat IDs)
TELEGRAM_MONITOR_CHANNELS=-1001111111111,-1002222222222

# Additional bot tokens for stream load balancing (comma-separated)
# Multiple bots distribute download pressure and avoid rate limits
TELEGRAM_BOT_TOKENS=bot_token_1,bot_token_2,bot_token_3

# External proxy (fallback, leave disabled if using sing-box)
PROXY_ENABLED=false
PROXY_SCHEME=socks5
PROXY_HOST=127.0.0.1
PROXY_PORT=10808

# sing-box built-in proxy (VLESS via Cloudflare)
SINGBOX_ENABLED=false
SINGBOX_ADDRESS=your_vless_address_here
SINGBOX_PORT=443
SINGBOX_UUID=your_vless_uuid_here
SINGBOX_PATH=/?ed=2048
SINGBOX_HOST=your_vless_host_here
SINGBOX_TLS=true
SINGBOX_FINGERPRINT=chrome
SINGBOX_SOCKS_PORT=10808

# Stream server
STREAM_HOST=0.0.0.0
STREAM_PORT=8001
BASE_URL=https://media.example.com
STREAM_LOCAL_URL=http://localhost:8001

# Stream download concurrency (number of parallel chunks per request)
STREAM_CONCURRENCY=3
# Max retry attempts for MTProto errors
STREAM_MAX_RETRIES=3
# Base delay (seconds) for exponential backoff between retries
STREAM_RETRY_DELAY=2.0

# TMDB API
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_LANGUAGE=zh-CN
TMDB_PROXY=
TMDB_IMAGE_CDN=https://wsrv.nl/?url=https://image.tmdb.org

# Database
DATABASE_URL=sqlite:///./data/media.db

# Cache
CACHE_DIR=./cache
MEDIA_PATH=./media
MEMORY_CACHE_SIZE=256
DISK_CACHE_MAX_GB=50

# STRM output directory
STRM_OUTPUT_DIR=./strm

# Cloudflare Worker (optional)
CF_WORKER_URL=
CF_WORKER_SECRET=

# Emby/Jellyfin
EMBY_HOST=http://localhost:8096
EMBY_API_KEY=
